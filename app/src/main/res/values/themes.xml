<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MadhuSiri" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>

        <!-- Tertiary brand color -->
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>

        <!-- Error -->
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>

        <!-- Surfaces & Background -->
        <item name="android:windowBackground">@color/md_theme_light_background</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorSurfaceContainer">@color/md_theme_light_surfaceContainer</item>
        <item name="colorSurfaceContainerHigh">@color/md_theme_light_surfaceContainerHigh</item>
        <item name="colorSurfaceContainerHighest">@color/md_theme_light_surfaceContainerHighest</item>
        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_light_outlineVariant</item>

        <!-- Status Bar — Edge-to-Edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Typography -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.MadhuSiri.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.MadhuSiri.DisplayMedium</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.MadhuSiri.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.MadhuSiri.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.MadhuSiri.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.MadhuSiri.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.MadhuSiri.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.MadhuSiri.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.MadhuSiri.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.MadhuSiri.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.MadhuSiri.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.MadhuSiri.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.MadhuSiri.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.MadhuSiri.LabelSmall</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.MadhuSiri.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MadhuSiri.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MadhuSiri.Large</item>

        <!-- Bottom Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.MadhuSiri.BottomNavigationView</item>

        <!-- Window Animation -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@android:transition/fade</item>
        <item name="android:windowExitTransition">@android:transition/fade</item>
    </style>

    <!-- ============================================================ -->
    <!--  Bottom Navigation                                           -->
    <!-- ============================================================ -->
    <style name="Widget.MadhuSiri.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget.MadhuSiri.BottomNavIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.MadhuSiri.LabelMedium</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.MadhuSiri.LabelSmall</item>
    </style>

    <style name="Widget.MadhuSiri.BottomNavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MadhuSiri.Small</item>
    </style>

    <!-- ============================================================ -->
    <!--  Material Card Overrides                                     -->
    <!-- ============================================================ -->
    <style name="Widget.MadhuSiri.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.MadhuSiri.Card.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- ============================================================ -->
    <!--  FAB Styles                                                  -->
    <!-- ============================================================ -->
    <style name="Widget.MadhuSiri.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="shapeAppearance">@style/ShapeAppearance.MadhuSiri.Medium</item>
        <item name="backgroundTint">@color/honey_gold</item>
        <item name="tint">@color/md_theme_light_onPrimary</item>
    </style>

    <style name="Widget.MadhuSiri.ExtendedFAB" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="backgroundTint">@color/honey_gold</item>
        <item name="android:textColor">@color/md_theme_light_onPrimary</item>
        <item name="iconTint">@color/md_theme_light_onPrimary</item>
    </style>

    <!-- ============================================================ -->
    <!--  Chip Styles                                                 -->
    <!-- ============================================================ -->
    <style name="Widget.MadhuSiri.Chip.Status" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">8dp</item>
        <item name="chipMinHeight">28dp</item>
    </style>
</resources>
