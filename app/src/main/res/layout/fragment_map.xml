<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Edge-to-edge Google Map view -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Unified Floating Information Banner Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="48dp"
        app:cardBackgroundColor="#E6000000"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeColor="#26FFFFFF"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title & Live Switch Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Geofence Controls"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="#B0B0B0" />

                    <TextView
                        android:id="@+id/tv_map_role_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="2km Proximity Scan"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Dedicated live location sync switch -->
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_live_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/honey_gold"
                    app:trackTint="#33FFB800" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_map_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Long press anywhere to drop a hive marker"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="#E0E0E0" />

            <!-- Clean Embedded Map Legend -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#1AFFFFFF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/honey_gold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Hive Marker"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="#FFFFFF" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/danger_red" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="2km Spray Danger"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Dedicated Custom Live Location Centering Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_my_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="112dp"
        android:contentDescription="Locate Me"
        app:srcCompat="@android:drawable/ic_menu_mylocation"
        app:tint="?attr/colorOnSurface"
        app:backgroundTint="?attr/colorSurfaceContainerHigh"
        app:elevation="6dp"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contextual Save Floating Action Button -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_save_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="180dp"
        android:text="Save Location"
        android:textColor="#1A0F00"
        app:icon="@android:drawable/ic_menu_save"
        app:iconTint="#1A0F00"
        app:backgroundTint="@color/honey_gold"
        app:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Center Aim Reticle Overlay for precise drops (optional support) -->
    <ImageView
        android:id="@+id/img_center_reticle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:tint="@color/honey_gold"
        android:alpha="0.3"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:importantForAccessibility="no" />

</androidx.constraintlayout.widget.ConstraintLayout>
