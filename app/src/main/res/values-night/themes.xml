<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MadhuSiri" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary: Bright Honey on OLED black -->
        <item name="colorPrimary">@color/md_theme_dark_primary</item>
        <item name="colorOnPrimary">@color/md_theme_dark_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_dark_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_dark_onPrimaryContainer</item>

        <!-- Secondary: Vibrant Green -->
        <item name="colorSecondary">@color/md_theme_dark_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_dark_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_dark_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_dark_onSecondaryContainer</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/md_theme_dark_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_dark_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_dark_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_dark_onTertiaryContainer</item>

        <!-- Error -->
        <item name="colorError">@color/md_theme_dark_error</item>
        <item name="colorOnError">@color/md_theme_dark_onError</item>
        <item name="colorErrorContainer">@color/md_theme_dark_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_dark_onErrorContainer</item>

        <!-- Premium OLED Surfaces -->
        <item name="android:windowBackground">@color/md_theme_dark_background</item>
        <item name="colorSurface">@color/md_theme_dark_surface</item>
        <item name="colorOnSurface">@color/md_theme_dark_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_dark_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="colorSurfaceContainer">@color/md_theme_dark_surfaceContainer</item>
        <item name="colorSurfaceContainerHigh">@color/md_theme_dark_surfaceContainerHigh</item>
        <item name="colorSurfaceContainerHighest">@color/md_theme_dark_surfaceContainerHighest</item>
        <item name="colorOutline">@color/md_theme_dark_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_dark_outlineVariant</item>

        <!-- Status Bar — Edge-to-Edge, dark icons off -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Typography (shared) -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.MadhuSiri.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.MadhuSiri.DisplayMedium</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.MadhuSiri.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.MadhuSiri.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.MadhuSiri.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.MadhuSiri.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.MadhuSiri.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.MadhuSiri.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.MadhuSiri.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.MadhuSiri.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.MadhuSiri.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.MadhuSiri.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.MadhuSiri.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.MadhuSiri.LabelSmall</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.MadhuSiri.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MadhuSiri.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MadhuSiri.Large</item>

        <!-- Bottom Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.MadhuSiri.BottomNavigationView</item>

        <!-- Window Animation -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@android:transition/fade</item>
        <item name="android:windowExitTransition">@android:transition/fade</item>
    </style>
</resources>
